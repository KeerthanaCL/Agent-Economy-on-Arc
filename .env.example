# --- Arc testnet ---
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_NETWORK=eip155:5042002
USDC_CONTRACT=0x3600000000000000000000000000000000000000

# --- x402 facilitator ---
# Circle Nanopayments / Gateway facilitator for Arc TESTNET.
# Mainnet would be https://gateway-api.circle.com
FACILITATOR_URL=https://gateway-api-testnet.circle.com

# --- Gemini ---
GEMINI_API_KEY=

# --- Circle (optional but recommended) ---
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=

# --- Agent EOA (local signer used by x402 client) ---
# Generated by scripts/setup_wallets.py — DO NOT commit real keys.
AGENT_PRIVATE_KEY=
AGENT_ADDRESS=

# --- Merchant wallets (receive payments) ---
# One merchant per paid API. Addresses only; keys not needed on server.
MERCHANT_PRICE_ADDRESS=
MERCHANT_SENTIMENT_ADDRESS=
MERCHANT_NEWS_ADDRESS=
# Analyst agent's merchant address — can reuse any of the above for a demo;
# merchant wallets only receive, never sign.
MERCHANT_ANALYST_ADDRESS=

# --- API servers ---
API_BASE_URL=http://localhost:8000
ANALYST_BASE_URL=http://localhost:8001

# --- Guardrails ---
MAX_SPEND_USD=0.05

# --- AI/ML API (used by analyst agent for Claude-powered synthesis) ---
AIML_API_KEY=
ANALYST_MODEL=claude-3-5-haiku-20241022
